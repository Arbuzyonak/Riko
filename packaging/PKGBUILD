pkgname=riko-launcher
pkgver=0.1.0
pkgrel=1
pkgdesc="GUI launcher for the Vortex gaming platform"
arch=('x86_64')
url="https://playvortex.io"
license=('MIT OR Apache-2.0')
depends=('webkit2gtk-4.1' 'gtk3' 'libayatana-appindicator')
optdepends=('wine: run the Vortex client'
            'winetricks: prefix setup'
            'gamemode: performance governor while playing'
            'vulkan-tools: doctor diagnostics')
makedepends=('cargo' 'npm' 'nodejs')
source=("$pkgname::git+file://${RIKO_REPO:-$(realpath ..)}")
sha256sums=('SKIP')

prepare() {
  cd "$pkgname/frontend"
  npm ci
}

build() {
  cd "$pkgname"
  ./frontend/node_modules/.bin/tauri build --no-bundle
}

package() {
  cd "$pkgname"
  install -Dm755 target/release/riko-launcher "$pkgdir/usr/bin/riko-launcher"
  install -Dm644 src-tauri/icons/128x128.png "$pkgdir/usr/share/icons/hicolor/128x128/apps/riko-launcher.png"
  install -Dm644 src-tauri/icons/32x32.png "$pkgdir/usr/share/icons/hicolor/32x32/apps/riko-launcher.png"
  install -Dm644 LICENSE-MIT "$pkgdir/usr/share/licenses/$pkgname/LICENSE-MIT"
  install -Dm644 LICENSE-APACHE "$pkgdir/usr/share/licenses/$pkgname/LICENSE-APACHE"
  install -Dm644 NOTICE.md "$pkgdir/usr/share/licenses/$pkgname/NOTICE.md"
  install -Dm644 /dev/stdin "$pkgdir/usr/share/applications/io.riko.launcher.desktop" <<'EOF'
[Desktop Entry]
Type=Application
Name=Riko Launcher
Comment=Launcher for the Vortex gaming platform
Exec=riko-launcher %u
Icon=riko-launcher
Terminal=false
Categories=Game;
MimeType=x-scheme-handler/vortex;
EOF
}
