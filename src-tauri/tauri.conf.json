{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Riko Launcher",
  "version": "0.1.0",
  "identifier": "io.riko.launcher",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ../frontend",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build --prefix ../frontend",
    "frontendDist": "../frontend/dist"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["vortex", "riko"]
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Riko Launcher",
        "width": 1200,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"]
  }
}
